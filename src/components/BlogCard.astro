---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category, thumbnail } = post.data;

const formattedDate = pubDate.toLocaleDateString('ko-KR', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<a class="card" href={`/blog/${post.id}`} data-category={category}>
	<div class="thumb">
		<Image src={thumbnail} alt={title} width={600} height={315} />
	</div>
	<div class="body">
		<span class="chip">{category}</span>
		<h2 class="title">{title}</h2>
		<p class="desc">{description}</p>
		<time class="date" datetime={pubDate.toISOString()}>{formattedDate}</time>
	</div>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
		border: 1px solid var(--border);
		border-radius: 12px;
		overflow: hidden;
		background: var(--bg);
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease;
	}

	.card:hover {
		transform: translateY(-3px);
		box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
	}

	.thumb {
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: var(--border);
	}

	.thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.body {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1rem 1.25rem 1.25rem;
	}

	.chip {
		align-self: flex-start;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		background: var(--text);
		color: var(--bg);
	}

	.title {
		font-size: 1.15rem;
		font-weight: 700;
		margin: 0;
		line-height: 1.4;
	}

	.desc {
		font-size: 0.9rem;
		color: var(--muted);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.date {
		font-size: 0.8rem;
		color: var(--muted);
		margin-top: 0.25rem;
	}
</style>
