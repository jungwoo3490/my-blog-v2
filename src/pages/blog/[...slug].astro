---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';

export const getStaticPaths = (async () => {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, category, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('ko-KR', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<Layout title={title} description={description}>
	<article>
		<a class="back" href="/">← 목록으로</a>

		<header class="head">
			<span class="chip">{category}</span>
			<h1>{title}</h1>
			<div class="meta">
				<time datetime={pubDate.toISOString()}>{formattedDate}</time>
				{tags.length > 0 && <span class="dot">·</span>}
				<ul class="tags">
					{tags.map((tag) => <li>#{tag}</li>)}
				</ul>
			</div>
		</header>

		<div class="prose">
			<Content />
		</div>
	</article>
</Layout>

<style>
	article {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 3rem 1.5rem 5rem;
	}

	.back {
		display: inline-block;
		font-size: 0.85rem;
		color: var(--muted);
		text-decoration: none;
		margin-bottom: 2rem;
	}
	.back:hover {
		color: var(--text);
	}

	.head {
		margin-bottom: 2.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border);
	}

	.chip {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		background: var(--text);
		color: var(--bg);
	}

	.head h1 {
		font-size: 2rem;
		font-weight: 800;
		line-height: 1.3;
		margin: 1rem 0 0.75rem;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: var(--muted);
	}
	.dot {
		color: var(--border);
	}
	.tags {
		display: flex;
		gap: 0.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.prose :global(h2) {
		font-size: 1.4rem;
		font-weight: 700;
		margin: 2.5rem 0 1rem;
	}
	.prose :global(h3) {
		font-size: 1.15rem;
		font-weight: 700;
		margin: 2rem 0 0.75rem;
	}
	.prose :global(p) {
		margin: 1rem 0;
	}
	.prose :global(a) {
		color: #2563eb;
		text-underline-offset: 2px;
	}
	.prose :global(ul),
	.prose :global(ol) {
		padding-left: 1.5rem;
		margin: 1rem 0;
	}
	.prose :global(li) {
		margin: 0.4rem 0;
	}
	.prose :global(pre) {
		padding: 1rem 1.25rem;
		border-radius: 8px;
		overflow-x: auto;
		font-size: 0.875rem;
		line-height: 1.6;
	}
	.prose :global(code) {
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.875em;
	}
	.prose :global(:not(pre) > code) {
		background: var(--border);
		padding: 0.15em 0.4em;
		border-radius: 4px;
	}
	.prose :global(blockquote) {
		border-left: 3px solid var(--border);
		padding-left: 1rem;
		margin: 1.5rem 0;
		color: var(--muted);
	}
	.prose :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 8px;
	}
</style>
